# Academic Writing Template - Content Exclusions
# Keep folder structure, ignore personal content

# Personal corpus and references
corpus/*
!corpus/.gitkeep

# Draft materials
drafts/*
!drafts/.gitkeep

# Manuscript content
manuscripts/*
!manuscripts/.gitkeep

# Figure collections
figures/*
!figures/.gitkeep

# Temporary files
*.tmp
*.bak
~*
*.swp
*.swo

# LaTeX temporary files
*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.synctex.gz
*.nav
*.snm
*.fdb_latexmk
*.fls

# Generated documents
*.pdf
*.docx
!templates/*.pdf
!templates/*.docx

# Python cache
__pycache__/
*.pyc
*.pyo

# Editor configs
.DS_Store
Thumbs.db
.vscode/
.idea/

# NPM package output
*.tgz
node_modules/

# NPM publishing config (maintained locally for releases)
package.json
.npmignore
scripts/

# Local settings (contains permissions/credentials)
.claude/settings.local.json

# Project-level skills (installed by npm postinstall from skills/)
.claude/skills/

# GSDAW local-only planning files (not pushed to remote)
# === Ephemeral state (never push) ===
.planning/STATE.md
.planning/ROADMAP.md
.planning/wave-plan.md
.planning/HANDOFF.json
.planning/PROJECT.md
.planning/phase-*-design.md
.planning/phases/
.planning/research-brief.json
.planning/literature.md
.planning/methodology.md
.planning/research-briefs/

