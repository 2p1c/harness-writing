# Academic Writing Template - Content Exclusions
# Keep folder structure, ignore personal content

# Personal corpus and references
corpus/*
!corpus/.gitkeep

# Draft materials
drafts/*
!drafts/.gitkeep

# Manuscript content
manuscripts/*
!manuscripts/.gitkeep

# Figure collections
figures/*
!figures/.gitkeep

# Temporary files
*.tmp
*.bak
~*
*.swp
*.swo

# LaTeX temporary files
*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.synctex.gz
*.nav
*.snm
*.fdb_latexmk
*.fls

# Generated documents
*.pdf
*.docx
!templates/*.pdf
!templates/*.docx

# Python cache
__pycache__/
*.pyc
*.pyo

# Editor configs
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local settings (contains permissions/credentials)
.claude/settings.local.json