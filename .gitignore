# Academic Writing Template - Content Exclusions
# Keep folder structure, ignore personal content

# Personal corpus and references (removed — empty dirs no longer exist)
# corpus/*
# drafts/*
# figures/*
# projects/*

# Manuscript content (tracked during framework development)
# manuscripts/*

# Temporary files
*.tmp
*.bak
~*
*.swp
*.swo

# LaTeX temporary files
*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.synctex.gz
*.nav
*.snm
*.fdb_latexmk
*.fls

# Generated documents
*.pdf
*.docx
!templates/*.pdf
!templates/*.docx

# Python cache
__pycache__/
*.pyc
*.pyo

# Editor configs
.DS_Store
Thumbs.db
.vscode/
.idea/

# NPM package output
*.tgz
node_modules/

# NPM publishing config (maintained locally for releases)
package.json
.npmignore
scripts/

# Claude Code project config (local only — never push)
.claude/

# Local agent skills mirror
.agents/

# Zotero temp data (ephemeral — never push)
.planning/.zotero-temp*
.planning/.zotero-temp*.json
.planning/.zotero-temp*.md
